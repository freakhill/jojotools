{
  "_comment": "Drop-in replacement for the Python server's .mcp.json. run.sh builds the Go server from source on first launch (requires Go on the target) and execs it. ${CLAUDE_PLUGIN_ROOT} is only expanded in args, not command — so launch via sh with the path in args (same reason the Python config used command:'uv' + path in args). The Go binary embeds models.json and fetches keys from `op` JIT exactly like the Python server.",
  "mcpServers": {
    "ai-router": {
      "command": "sh",
      "args": ["${CLAUDE_PLUGIN_ROOT}/go/run.sh"]
    }
  }
}
