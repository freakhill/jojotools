# jojotools — bring your own credentials. ai-router resolves each key just-in-time from
# 1Password (the `op` CLI), or from an env fallback. Nothing here ships a key.
# Full matrix: docs/SETUP.md.

# 1Password vault holding the key items (kimi-api-key, glm-api-key, openrouter-api-key).
AI_ROUTER_OP_VAULT=claude

# Raw-key fallbacks, used only if `op` yields nothing.
# OpenRouter is 1Password-only by design (no standing key export).
# KIMI_API_KEY=
# GLM_API_KEY=

# Optional.
# AI_ROUTER_FALLBACK_DIR=/tmp
# AGENT_MEM_REPO=$HOME/.claude/agent-memory
# WOLOLO_OUTPUT_DIR=$HOME/wololo-runs
